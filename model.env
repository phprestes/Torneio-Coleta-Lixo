# Configurações do Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# Flag para recriar as tabelas do zero sempre que o programa iniciar (se true, as tabelas são dropadas e recriadas)
ALWAYS_RECREATE_DB=true

# Configurações do PgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
